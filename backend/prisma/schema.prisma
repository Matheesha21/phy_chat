
// Prisma schema for the USJ Physics Department AI Assistant.
// Fields mirror the frontend TypeScript interfaces in the `services/` layer.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Lecture {
  id         Int      @id @default(autoincrement())
  courseCode String
  courseName String
  time       String
  lecturer   String
  hall       String
  day        String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Lecturer {
  id             Int      @id @default(autoincrement())
  name           String
  title          String
  specialization String
  email          String
  officeHours    String
  room           String
  imageUrl       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

enum HallType {
  Auditorium
  LectureRoom
  Laboratory
}

model Hall {
  id           Int      @id @default(autoincrement())
  name         String
  location     String
  capacity     Int
  hasProjector Boolean  @default(false)
  type         HallType
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
